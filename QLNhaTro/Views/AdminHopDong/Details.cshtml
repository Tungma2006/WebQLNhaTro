@model QLNhaTro.Models.HopDong

@{
    ViewData["Title"] = "Chi tiết hợp đồng";
}

<style>
    .contract-container {
        max-width: 800px;
        margin: auto;
        background: #fff;
        padding: 40px;
        border-radius: 10px;
        box-shadow: 0 0 20px rgba(0,0,0,0.1);
        font-family: "Times New Roman", Times, serif; /* Font chữ chuẩn hợp đồng */
        line-height: 1.6;
    }

    .contract-title {
        text-align: center;
        font-size: 26px;
        font-weight: bold;
        margin-bottom: 30px;
        text-transform: uppercase;
        color: #000;
    }

    .section {
        margin-bottom: 25px;
    }

    .section-title {
        font-weight: bold;
        font-size: 18px;
        margin-bottom: 10px;
        color: #000;
        text-decoration: underline;
    }

    .info-row {
        margin-bottom: 8px;
        font-size: 16px;
    }

    .footer {
        margin-top: 50px;
        display: flex;
        justify-content: space-between;
        text-align: center;
    }

    .signature-space {
        margin-top: 80px;
        font-style: italic;
    }

    .btn-group {
        margin-top: 30px;
        text-align: center;
    }

    /* Ẩn nút khi in hợp đồng */
    @@media print {
        .btn-group, .navbar, footer {
            display: none !important;
        }

        .contract-container {
            box-shadow: none;
            padding: 0;
        }
    }
</style>

<div class="contract-container">
    <div class="contract-title">
        CỘNG HÒA XÃ HỘI CHỦ NGHĨA VIỆT NAM<br />
        <small>Độc lập - Tự do - Hạnh phúc</small>
        <hr />
        HỢP ĐỒNG THUÊ PHÒNG TRỌ
    </div>

    <div class="section">
        <div class="section-title">1. THÔNG TIN CÁC BÊN</div>

        <div class="info-row"><strong>Bên cho thuê (Bên A):</strong> Ông/Bà Tùng</div>

        <div class="info-row">
            <strong>Bên thuê (Bên B):</strong>
            @(Model.NguoiThue?.NguoiThueName ?? "................................")
        </div>

        <div class="info-row">
            <strong>Số CCCD:</strong>
            @(Model.NguoiThue?.CCCD ?? "................................")
        </div>
    </div>

    <div class="section">
        <div class="section-title">2. NỘI DUNG THUÊ</div>
        <div class="info-row">
            <strong>Thuê tại phòng:</strong>
            @(Model.Phong?.TenPhong ?? "................")
        </div>
        <div class="info-row">
            <strong>Thời hạn thuê:</strong>
            Từ ngày @Model.NgayBatdau.ToString("dd/MM/yyyy")
            đến ngày @Model.NgayKetThuc.ToString("dd/MM/yyyy")
        </div>
        <div class="info-row">
            <strong>Tiền đặt cọc:</strong>
            @Model.TienDatCoc.ToString("N0") VNĐ
        </div>
    </div>

    <div class="section">
        <div class="section-title">3. CHI PHÍ VÀ ĐIỀU KHOẢN</div>
        <div class="info-row">- Tiền phòng thanh toán hàng tháng: 1,000,000 đ</div>
        <div class="info-row">- Giá điện: 3,500 đ/kwh - Giá nước: 10,000 đ/m3</div>
        <div class="info-row">- Thời hạn thanh toán: <strong>Trước ngày 10 hàng tháng.</strong></div>
        <div class="info-row">- Nếu vi phạm quy định nhà trọ, bên A có quyền chấm dứt hợp đồng.</div>
    </div>

    <div class="footer">
        <div>
            <strong>ĐẠI DIỆN BÊN A</strong><br />
            (Ký và ghi rõ họ tên)
            <div class="signature-space">Tùng</div>
        </div>

        <div>
            <strong>ĐẠI DIỆN BÊN B</strong><br />
            (Ký và ghi rõ họ tên)
            <div class="signature-space">
                @(Model.NguoiThue?.NguoiThueName)
            </div>
        </div>
    </div>

    <div class="btn-group">
        <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
        <button onclick="window.print()" class="btn btn-primary">In hợp đồng</button>
    </div>
</div>